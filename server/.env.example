# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=sanad_pillbox
DB_PASSWORD=your_db_password
DB_PORT=5432

# For Docker Compose
POSTGRES_PASSWORD=your_db_password
DATABASE_URL=postgresql://postgres:your_db_password@postgres:5432/sanad_pillbox

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# ── MinIO (object storage) ────────────────────────────────────────────────────
# Set MINIO_PUBLIC_HOST to your machine's LAN IP (run: ipconfig getifaddr en0)
MINIO_PUBLIC_HOST=192.168.X.X
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Download your service account JSON from Firebase Console:
#   Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
